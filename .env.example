# ARGUS environment variables
# Copy to `.env` for local docker compose: `cp .env.example .env`
# Values below are placeholders — fill in as each phase lands.

# =============================================================================
# Phase 0 — local messaging (Redpanda)
# =============================================================================
# Host-side Kafka API advertised by compose (see docker-compose.yml)
KAFKA_BROKERS=localhost:19092
# In-compose service address for other containers (when added):
# KAFKA_BROKERS=redpanda:9092
REDPANDA_SCHEMA_REGISTRY_URL=http://localhost:18081

