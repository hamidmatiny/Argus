# ARGUS environment variables
# Copy to `.env` for local docker compose: `cp .env.example .env`
# Values below are placeholders — fill in as each phase lands.

# =============================================================================
# Phase 0 — local messaging (Redpanda)
# =============================================================================
# Host-side Kafka API advertised by compose (see docker-compose.yml)
KAFKA_BROKERS=localhost:19092
# In-compose service address for other containers (when added):
# KAFKA_BROKERS=redpanda:9092
REDPANDA_SCHEMA_REGISTRY_URL=http://localhost:18081

# =============================================================================
# Phase 1 — shared contracts / schema registry
# =============================================================================
# Redpanda built-in Confluent-compatible Schema Registry (host port)
SCHEMA_REGISTRY_URL=http://localhost:18081
# Subject prefix used by `make register-avro` (e.g. argus.telemetry.TelemetryEvent-value)
ARGUS_SCHEMA_SUBJECT_PREFIX=argus
# Redpanda Console UI (host :8087 → container :8080)
REDPANDA_CONSOLE_URL=http://localhost:8087

# =============================================================================
# Phase 2 — ingestion / Ray
# =============================================================================
# Compose uses redpanda:9092; host-side standalone uses localhost:19092
# KAFKA_BROKERS=redpanda:9092
SIMULATOR_VEHICLES=12
SIMULATOR_RATE=10
SIMULATOR_DURATION=0
SIMULATOR_FAILURE_RATE=0.05
SIMULATOR_TOPIC=telemetry.raw
SIMULATOR_HEALTH_PORT=8091
INGESTION_KAFKA_GROUP_ID=argus-ingestion
INGESTION_RAW_TOPIC=telemetry.raw
INGESTION_NORMALIZED_TOPIC=telemetry.normalized
INGESTION_QUARANTINE_TOPIC=telemetry.quarantine
RAY_NUM_PARTITIONS=2
RAY_NUM_CPUS=2
RAY_BATCH_SIZE=50
# Explicit Ray memory budgets for cgroup-limited containers (bytes).
# Defaults: object store 256MB, task/actor heap 512MB.
RAY_OBJECT_STORE_MEMORY_BYTES=268435456
RAY_MEMORY_BYTES=536870912
# Ray dashboard is memory-heavy; keep false under the 2Gi compose limit.
RAY_INCLUDE_DASHBOARD=false
RAY_HEALTH_PORT=8092
RAY_DASHBOARD_PORT=8265
ARGUS_AVRO_SCHEMA_PATH=shared/avro/telemetry_event.avsc

# =============================================================================
# Phase 3 — stream-processor / Flink QA
# =============================================================================
QA_ENGINE=local
QA_SOURCE_TOPIC=telemetry.normalized
QA_VALIDATED_TOPIC=telemetry.validated
QA_QUARANTINE_TOPIC=telemetry.quarantine
QA_METRICS_TOPIC=telemetry.qa_metrics
QA_KAFKA_GROUP_ID=argus-stream-processor
QA_WINDOW_EVENTS=20
QA_QUARANTINE_RATE_THRESHOLD=0.15
QA_HEALTH_PORT=8093
FLINK_JOBMANAGER_URL=http://localhost:8088
FLINK_PARALLELISM=1

# =============================================================================
# Phase 5 — lakehouse / Iceberg (MinIO local, Glue+S3 prod)
# =============================================================================
ICEBERG_CATALOG_TYPE=rest
ICEBERG_CATALOG_URI=http://localhost:8181
ICEBERG_WAREHOUSE=s3://warehouse/
ICEBERG_NAMESPACE=fleet
ICEBERG_TELEMETRY_TABLE=telemetry
ICEBERG_QUARANTINE_TABLE=quarantine
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
S3_ENDPOINT=http://localhost:9000
S3_PATH_STYLE_ACCESS=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
# Prod Glue (Phase 12+): ICEBERG_CATALOG_TYPE=glue GLUE_DATABASE=fleet
LAKEHOUSE_BATCH_SIZE=50
LAKEHOUSE_FLUSH_INTERVAL_SEC=5
LAKEHOUSE_WRITER_HEALTH_PORT=8096
LAKEHOUSE_DLQ_HEALTH_PORT=8097

# =============================================================================
# Phase 6 — orchestration / Dagster + MLflow
# =============================================================================
DAGSTER_HOME=./orchestration
MLFLOW_TRACKING_URI=http://localhost:5002
MLFLOW_EXPERIMENT_NAME=argus-retraining
POSTGRES_MLOPS_USER=argus
POSTGRES_MLOPS_PASSWORD=argus
POSTGRES_MLOPS_DB=mlops
ORCH_RETRAINING_TOPIC=orchestration.retraining_triggered
ORCH_RETRAIN_MAX_SCORE_THRESHOLD=0.5
ORCH_RETRAIN_MIN_DRIFTED_FEATURES=2

# =============================================================================
# Phase 4 — drift-monitor
# =============================================================================
DRIFT_SOURCE_TOPIC=telemetry.validated
DRIFT_INCIDENTS_TOPIC=incidents.raw
DRIFT_KAFKA_GROUP_ID=argus-drift-monitor
DRIFT_BASELINE_SAMPLES=200
DRIFT_BASELINE_WARMUP_SAMPLES=200
DRIFT_WINDOW_SIZE=50
DRIFT_ALPHA=0.05
DRIFT_MIN_FEATURES_FOR_INCIDENT=2
DRIFT_USE_LIVE_BASELINE=true
EMBEDDING_COSINE_SIM_THRESHOLD=0.85
EMBEDDING_EUCLIDEAN_THRESHOLD=2.0
DRIFT_HEALTH_PORT=8094
DRIFT_METRICS_PORT=8095
# Evidently deep-dive cadence (tumbling windows of DRIFT_WINDOW_SIZE).
# Prometheus/KS scores still update every sliding evaluation.
DRIFT_EVIDENTLY_EVERY_N_WINDOWS=30
# Cap timestamped data_drift_*.{html,json} stems retained on disk.
DRIFT_REPORTS_MAX_FILES=48

# =============================================================================
# Phase 7 — incident-engine (Go + OPA)
# =============================================================================
INCIDENT_ENGINE_ADDR=:8098
INCIDENT_ENGINE_KAFKA_GROUP_ID=argus-incident-engine
INCIDENTS_RAW_TOPIC=incidents.raw
INCIDENTS_ESCALATED_TOPIC=incidents.escalated
INCIDENT_QA_WINDOW_BATCHES=5
INCIDENT_QA_RATE_THRESHOLD=0.15
INCIDENT_DRIFT_MIN_FEATURES=2
INCIDENT_CONSECUTIVE_FAILURES=3
INCIDENT_OPEN_COOLDOWN_SEC=60
INCIDENT_ENABLE_MOCK_WEBHOOK=true
# INCIDENT_SLACK_WEBHOOK_URL=
# INCIDENT_PAGERDUTY_WEBHOOK_URL=

# =============================================================================
# Phase 9 — api-gateway (OIDC / Keycloak / OPA)
# =============================================================================
API_GATEWAY_ADDR=:8099
API_GATEWAY_GRPC_ADDR=:9099
API_GATEWAY_AUTH_DISABLED=false
OIDC_ISSUER_URL=http://localhost:8085/realms/argus
OIDC_AUDIENCE=argus-gateway
OIDC_JWKS_URL=http://keycloak:8080/realms/argus/protocol/openid-connect/certs
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
API_GATEWAY_API_KEYS=demo-viewer:viewer,demo-operator:operator,demo-admin:admin
API_GATEWAY_RATE_LIMIT_RPS=20
API_GATEWAY_RATE_LIMIT_BURST=40
INCIDENT_ENGINE_URL=http://localhost:8098
TRINO_URL=http://localhost:8089
DAGSTER_GRAPHQL_URL=http://localhost:3000/graphql

# =============================================================================
# Phase 8 — observability / OpenTelemetry
# =============================================================================
# In-compose services use otel-collector:4318; host-side exporters use localhost.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=argus
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=argus
# Host URLs for demos:
# Grafana http://localhost:3001
# Prometheus http://localhost:9090
# Alertmanager http://localhost:9093
# Jaeger http://localhost:16686
# Loki http://localhost:3100/ready
# On-call report http://localhost:8100/report

# =============================================================================
# Phase 13 — ai-copilot / LLM providers
# =============================================================================
# Set secrets via: argusctl secrets set OPENAI_API_KEY="..."
# Never commit real keys. LLM_PROVIDER=mock runs offline (compose default).
LLM_PROVIDER=mock
# LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic
# LLM_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# LLM_API_BASE_URL=
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=hash
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
COPILOT_ADDR=:8090
QDRANT_URL=http://localhost:6333
AI_COPILOT_URL=http://ai-copilot:8090
COPILOT_MAX_TOOL_DEPTH=6
# COPILOT_RAG_INDEX_URI=  # reserved

# =============================================================================
# Phase 10 — dashboard (Next.js)
# =============================================================================
# Browser origin for NextAuth callbacks (must match the host:port you open).
NEXTAUTH_URL=http://localhost:3002
# Session encryption secret (required). Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
KEYCLOAK_CLIENT_ID=argus-dashboard
KEYCLOAK_CLIENT_SECRET=argus-dashboard-secret
# Offline demo login (viewer/operator/admin) when Keycloak is unavailable
AUTH_DEMO_OFFLINE=true
# DASHBOARD_API_BASE_URL=http://localhost:8099
# DASHBOARD_COPILOT_URL=http://localhost:8090

# =============================================================================
# Phase — CLI / SDKs (TODO)
# =============================================================================
# ARGUS_API_URL=http://localhost:8088
# ARGUS_API_TOKEN=

# =============================================================================
# Phase — production / infra hints (TODO; prefer secrets managers in real envs)
# =============================================================================
# ENVIRONMENT=local
# LOG_LEVEL=info
# LOG_FORMAT=json
