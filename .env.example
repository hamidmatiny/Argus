# ARGUS environment variables
# Copy to `.env` for local docker compose: `cp .env.example .env`
# Values below are placeholders — fill in as each phase lands.

# =============================================================================
# Phase 0 — local messaging (Redpanda)
# =============================================================================
# Host-side Kafka API advertised by compose (see docker-compose.yml)
KAFKA_BROKERS=localhost:19092
# In-compose service address for other containers (when added):
# KAFKA_BROKERS=redpanda:9092
REDPANDA_SCHEMA_REGISTRY_URL=http://localhost:18081

# =============================================================================
# Phase 1 — shared contracts / schema registry
# =============================================================================
# Redpanda built-in Confluent-compatible Schema Registry (host port)
SCHEMA_REGISTRY_URL=http://localhost:18081
# Subject prefix used by `make register-avro` (e.g. argus.telemetry.TelemetryEvent-value)
ARGUS_SCHEMA_SUBJECT_PREFIX=argus
# Redpanda Console UI (host :8087 → container :8080)
REDPANDA_CONSOLE_URL=http://localhost:8087

# =============================================================================
# Phase 2 — ingestion / Ray
# =============================================================================
# Compose uses redpanda:9092; host-side standalone uses localhost:19092
# KAFKA_BROKERS=redpanda:9092
SIMULATOR_VEHICLES=5
SIMULATOR_RATE=10
SIMULATOR_DURATION=0
SIMULATOR_FAILURE_RATE=0.05
SIMULATOR_TOPIC=telemetry.raw
SIMULATOR_HEALTH_PORT=8091
INGESTION_KAFKA_GROUP_ID=argus-ingestion
INGESTION_RAW_TOPIC=telemetry.raw
INGESTION_NORMALIZED_TOPIC=telemetry.normalized
RAY_NUM_PARTITIONS=2
RAY_NUM_CPUS=2
RAY_BATCH_SIZE=50
# Explicit Ray memory budgets for cgroup-limited containers (bytes).
# Defaults: object store 256MB, task/actor heap 512MB.
RAY_OBJECT_STORE_MEMORY_BYTES=268435456
RAY_MEMORY_BYTES=536870912
# Ray dashboard is memory-heavy; keep false under the 2Gi compose limit.
RAY_INCLUDE_DASHBOARD=false
RAY_HEALTH_PORT=8092
RAY_DASHBOARD_PORT=8265
ARGUS_AVRO_SCHEMA_PATH=shared/avro/telemetry_event.avsc

# =============================================================================
# Phase 3 — stream-processor / Flink QA
# =============================================================================
QA_ENGINE=local
QA_SOURCE_TOPIC=telemetry.normalized
QA_VALIDATED_TOPIC=telemetry.validated
QA_QUARANTINE_TOPIC=telemetry.quarantine
QA_METRICS_TOPIC=telemetry.qa_metrics
QA_KAFKA_GROUP_ID=argus-stream-processor
QA_WINDOW_EVENTS=20
QA_QUARANTINE_RATE_THRESHOLD=0.15
QA_HEALTH_PORT=8093
FLINK_JOBMANAGER_URL=http://localhost:8088
FLINK_PARALLELISM=1

