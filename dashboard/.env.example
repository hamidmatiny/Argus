# NextAuth (v4) — required for session encryption. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3002

KEYCLOAK_ISSUER=http://localhost:8085/realms/argus
KEYCLOAK_CLIENT_ID=argus-dashboard
KEYCLOAK_CLIENT_SECRET=argus-dashboard-secret
ARGUS_GATEWAY_URL=http://localhost:8099
PROMETHEUS_URL=http://localhost:9090
DAGSTER_GRAPHQL_URL=http://localhost:3000/graphql
MLFLOW_TRACKING_URI=http://localhost:5002
# Offline demo login (viewer/operator/admin) when Keycloak is unavailable
AUTH_DEMO_OFFLINE=false
