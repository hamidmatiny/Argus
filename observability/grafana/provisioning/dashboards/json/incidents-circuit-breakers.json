{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "stat",
      "title": "Open circuit breakers",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        { "expr": "argus:breakers_open", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Breaker trip rate (/s)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        { "expr": "argus:breaker_trip_rate", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Escalations (total)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        { "expr": "argus_incident_escalations_published_total", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Webhooks delivered",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        { "expr": "argus_incident_webhooks_delivered_total", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "timeseries",
      "title": "Per-vehicle breaker state (0=closed, 1=half_open, 2=open)",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        {
          "expr": "argus_incident_breaker_state",
          "legendFormat": "{{vehicle_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 2,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "auto",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Policy eval latency",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(argus_incident_policy_eval_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(argus_incident_policy_eval_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Retraining / escalation trigger frequency (15m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        {
          "expr": "argus:retraining_trigger_rate",
          "legendFormat": "trigger rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Incident events processed rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "argus-prometheus" },
      "targets": [
        {
          "expr": "rate(argus_incident_events_processed_total[5m])",
          "legendFormat": "processed/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" }
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["argus", "incidents", "breakers"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Incidents & Circuit Breakers",
  "uid": "argus-incidents-breakers",
  "version": 1
}
